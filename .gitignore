# Dependencies
node_modules/

# Build output
dist/
build/
*.tsbuildinfo

# Environment & secrets (never commit real credentials)
.env
.env.*
!.env.example

# Logs & runtime
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Prisma generated client (regenerate with: npm run prisma:generate)
/generated/

# Test coverage
coverage/
.nyc_output/

# Runtime backups (generated ZIP files)
backups/

.cache/
.temp/
tmp/
temp/

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Local editor history (e.g. Local History extensions)
.history/

# Certificates & keys
*.pem
*.key
*.p12
*.pfx
