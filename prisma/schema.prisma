// Tea Estate Management System — database schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum EstateStatus {
  active
  inactive
}

enum SectionStatus {
  active
  inactive
}

enum UserRole {
  Administrator
  Planter
  Supervisor
}

enum UserStatus {
  active
  inactive
}

enum Gender {
  Male
  Female
  Other
}

enum EmployeeStatus {
  active
  inactive
}

enum ServiceStatus {
  active
  inactive
}

enum UnitType {
  Hours
  Acres
  Units
  KG
}

enum AssignmentStatus {
  pending
  approved
  completed
}

enum ExpenseCategory {
  Transport
  Tools
  Utilities
  Other
}

enum ExpenseStatus {
  pending
  approved
  rejected
}

enum Recurrence {
  none
  daily
  weekly
  monthly
  yearly
}

enum EventCategory {
  Meeting
  Cultivation
  Maintenance
  Review
  Finance
  Training
  Other
}

enum BackupType {
  Auto
  Manual
}

enum BackupStatus {
  success
  failed
}

enum BackupSchedule {
  daily
  weekly
  monthly
}

// ─── Core entities ───────────────────────────────────────────────────────────

model Estate {
  id              String       @id @default(cuid())
  name            String
  location        String
  mapsLink        String?      @db.Text
  area            Float?
  establishedYear Int?
  planter         String?
  supervisor      String?
  status          EstateStatus @default(active)
  isDeleted       Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  sections         Section[]
  employees        Employee[]
  expenses         Expense[]
  dailyAssignments DailyAssignment[]
  calendarEvents   CalendarEvent[]
  assignedUsers    User[]

  @@index([status])
  @@map("estate")
}

model Section {
  id          String        @id @default(cuid())
  estateId    String
  name        String
  area        Float?
  description String?       @db.Text
  status      SectionStatus @default(active)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  estate           Estate            @relation(fields: [estateId], references: [id], onDelete: Cascade)
  dailyAssignments DailyAssignment[]
  expenses         Expense[]

  @@index([estateId])
  @@index([status])
  @@map("section")
}

model User {
  id               String     @id @default(cuid())
  name             String
  email            String     @unique
  phone            String?
  address          String?    @db.Text
  role             UserRole
  registeredDate   DateTime   @default(now())
  status           UserStatus @default(active)
  assignedEstateId String?
  passwordHash     String
  profilePhoto     String?    @db.Text
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  assignedEstate Estate? @relation(fields: [assignedEstateId], references: [id], onDelete: SetNull)

  @@index([role])
  @@index([status])
  @@index([assignedEstateId])
  @@map("user")
}

model Service {
  id          String        @id @default(cuid())
  name        String
  description String?       @db.Text
  status      ServiceStatus @default(active)
  rate        Decimal       @db.Decimal(12, 2)
  unitType    UnitType
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  employeeServices EmployeeService[]
  dailyAssignments DailyAssignment[]

  @@index([status])
  @@map("service")
}

model Employee {
  id        String         @id // Format: EMP001, EMP002 — generated in application layer
  name      String
  gender    Gender
  phone     String?
  nic       String         @unique
  estateId  String
  status    EmployeeStatus @default(active)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  estate            Estate             @relation(fields: [estateId], references: [id], onDelete: Restrict)
  serviceCategories EmployeeService[]
  workerAssignments WorkerAssignment[]

  @@index([estateId])
  @@index([status])
  @@map("employee")
}

model EmployeeService {
  employeeId String
  serviceId  String

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([employeeId, serviceId])
  @@index([serviceId])
  @@map("employeeservice")
}

model DailyAssignment {
  id          String           @id @default(cuid())
  date        DateTime         @db.Date
  estateId    String
  sectionId   String
  serviceId   String
  totalAmount Decimal          @default(0) @db.Decimal(12, 2)
  status      AssignmentStatus @default(pending)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  estate  Estate  @relation(fields: [estateId], references: [id], onDelete: Restrict)
  section Section @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  workerAssignments WorkerAssignment[]

  @@index([date])
  @@index([estateId])
  @@index([status])
  @@index([estateId, date])
  @@map("dailyassignment")
}

model WorkerAssignment {
  id                String   @id @default(cuid())
  dailyAssignmentId String
  employeeId        String
  unitsCompleted    Decimal  @default(0) @db.Decimal(12, 2)
  paymentAmount     Decimal  @default(0) @db.Decimal(12, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  dailyAssignment DailyAssignment @relation(fields: [dailyAssignmentId], references: [id], onDelete: Cascade)
  employee        Employee        @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@unique([dailyAssignmentId, employeeId])
  @@index([employeeId])
  @@map("workerassignment")
}

model Expense {
  id          String          @id @default(cuid())
  date        DateTime        @db.Date
  category    ExpenseCategory
  description String          @db.Text
  amount      Decimal         @db.Decimal(12, 2)
  estateId    String
  sectionId   String?
  status      ExpenseStatus   @default(pending)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  estate  Estate   @relation(fields: [estateId], references: [id], onDelete: Restrict)
  section Section? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  @@index([date])
  @@index([estateId])
  @@index([status])
  @@index([category])
  @@map("expense")
}

model CalendarEvent {
  id          String        @id @default(cuid())
  title       String
  description String?       @db.Text
  startDate   DateTime      @db.Date
  endDate     DateTime?     @db.Date
  recurrence  Recurrence    @default(none)
  color       String
  category    EventCategory
  estateId    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  estate Estate? @relation(fields: [estateId], references: [id], onDelete: SetNull)

  @@index([startDate])
  @@index([estateId])
  @@map("calendarevent")
}

model BackupRecord {
  id        String       @id @default(cuid())
  filename  String
  type      BackupType
  sizeKB    Int
  records   Int?
  status    BackupStatus
  filePath  String
  createdAt DateTime     @default(now())

  @@index([createdAt])
  @@map("backuprecord")
}

model BackupSettings {
  id        Int            @id @default(1)
  enabled   Boolean        @default(false)
  schedule  BackupSchedule @default(daily)
  updatedAt DateTime       @updatedAt

  @@map("backupsettings")
}
